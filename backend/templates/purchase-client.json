{
  "subject": "🎉 Obrigado pela sua compra - Archeon",
  "body": "<div class=\"section\">\n      <h1 style=\"font-family: 'Cinzel', serif; font-size: 28px; color: #030213; margin-bottom: 10px;\">\n        Obrigado pela sua compra!\n      </h1>\n      <p style=\"font-size: 16px; color: #717182;\">\n        Sua compra foi processada com sucesso. Estamos empolgados para ajudar a dar vida aos seus projetos criativos!\n      </p>\n    </div>\n\n    <div class=\"highlight-box\">\n      <div class=\"highlight-title\">Compra Confirmada</div>\n      <div class=\"highlight-value\">#{{orderId}}</div>\n      <div class=\"highlight-subtitle\">{{orderDate}}</div>\n    </div>\n\n    <div class=\"section\">\n      <h2 class=\"section-title\">📦 Produtos Comprados</h2>\n      <table class=\"table\">\n        <thead>\n          <tr>\n            <th>Produto</th>\n            <th>Categoria</th>\n            <th>Preço</th>\n          </tr>\n        </thead>\n        <tbody>\n          {{#each items}}\n          <tr>\n            <td>{{name}}</td>\n            <td>{{category}}</td>\n            <td>R$ {{price}}</td>\n          </tr>\n          {{/each}}\n        </tbody>\n        <tfoot>\n          <tr class=\"total-row\">\n            <td colspan=\"2\"><strong>Total Pago</strong></td>\n            <td><strong>R$ {{totalAmount}}</strong></td>\n          </tr>\n        </tfoot>\n      </table>\n    </div>\n\n    <div class=\"section\">\n      <h2 class=\"section-title\">🎮 Gamificação</h2>\n      <div class=\"info-grid\">\n        <div class=\"info-item\">\n          <div class=\"info-label\">Pontos Ganhos</div>\n          <div class=\"info-value\">{{pointsEarned}} pontos</div>\n        </div>\n        <div class=\"info-item\">\n          <div class=\"info-label\">Pontos Totais</div>\n          <div class=\"info-value\">{{totalPoints}} pontos</div>\n        </div>\n        <div class=\"info-item\">\n          <div class=\"info-label\">Seu Nível</div>\n          <div class=\"info-value\">{{level}}</div>\n        </div>\n        <div class=\"info-item\">\n          <div class=\"info-label\">Título Atual</div>\n          <div class=\"info-value\">{{title}}</div>\n        </div>\n      </div>\n    </div>\n\n    {{#if newReward}}\n    <div class=\"section\">\n      <h2 class=\"section-title\">🎁 Nova Recompensa Desbloqueada!</h2>\n      <div class=\"highlight-box\">\n        <div class=\"highlight-title\">{{newReward.name}}</div>\n        <div class=\"highlight-value\">{{newReward.description}}</div>\n      </div>\n    </div>\n    {{/if}}\n\n    <div class=\"section\">\n      <h2 class=\"section-title\">👤 Seus Dados</h2>\n      <div class=\"info-grid\">\n        <div class=\"info-item\">\n          <div class=\"info-label\">Nome de Usuário</div>\n          <div class=\"info-value\">{{username}}</div>\n        </div>\n        <div class=\"info-item\">\n          <div class=\"info-label\">Email</div>\n          <div class=\"info-value\">{{email}}</div>\n        </div>\n        <div class=\"info-item\">\n          <div class=\"info-label\">Serviços Completados</div>\n          <div class=\"info-value\">{{servicesCompleted}}</div>\n        </div>\n        <div class=\"info-item\">\n          <div class=\"info-label\">Data da Compra</div>\n          <div class=\"info-value\">{{orderDate}}</div>\n        </div>\n      </div>\n    </div>\n\n    <div style=\"text-align: center; margin: 30px 0;\">\n      <a href=\"#\" class=\"button\">Ver Meu Perfil</a>\n      <a href=\"#\" class=\"button\">Continuar Comprando</a>\n    </div>\n\n    <div class=\"section\">\n      <p style=\"font-size: 14px; color: #717182; text-align: center;\">\n        Se você tiver alguma dúvida sobre sua compra, entre em contato conosco.<br>\n        Estamos aqui para ajudar a tornar seus projetos incríveis!\n      </p>\n    </div>"
}