{
  "subject": "🎨 Nova Solicitação de Projeto - Ticket #{{ticketId}}",
  "body": "<div class=\"section\">\n      <h1 style=\"font-family: 'Cinzel', serif; font-size: 28px; color: #030213; margin-bottom: 10px;\">\n        Nova Solicitação de Projeto!\n      </h1>\n      <p style=\"font-size: 16px; color: #717182;\">\n        Um cliente entrou em contato através do formulário \"Solicitar Projeto\". Detalhes da solicitação abaixo.\n      </p>\n    </div>\n\n    <div class=\"highlight-box\">\n      <div class=\"highlight-title\">Ticket de Serviço</div>\n      <div class=\"highlight-value\">#{{ticketId}}</div>\n      <div class=\"highlight-subtitle\">{{requestDate}}</div>\n    </div>\n\n    <div class=\"section\">\n      <h2 class=\"section-title\">👤 Dados do Cliente</h2>\n      <div class=\"info-grid\">\n        <div class=\"info-item\">\n          <div class=\"info-label\">Nome</div>\n          <div class=\"info-value\">{{name}}</div>\n        </div>\n        <div class=\"info-item\">\n          <div class=\"info-label\">Email</div>\n          <div class=\"info-value\">{{email}}</div>\n        </div>\n        <div class=\"info-item\">\n          <div class=\"info-label\">Telefone</div>\n          <div class=\"info-value\">{{phone}}</div>\n        </div>\n        <div class=\"info-item\">\n          <div class=\"info-label\">Tipo de Serviço</div>\n          <div class=\"info-value\">{{serviceType}}</div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"section\">\n      <h2 class=\"section-title\">📝 Descrição do Projeto</h2>\n      <div style=\"background-color: #f8f9fa; padding: 20px; border-radius: 8px; border-left: 4px solid #030213;\">\n        <p style=\"font-size: 16px; line-height: 1.6; color: #030213; margin: 0;\">\n          {{description}}\n        </p>\n      </div>\n    </div>\n\n    {{#if references}}\n    <div class=\"section\">\n      <h2 class=\"section-title\">🔗 Referências</h2>\n      <div style=\"background-color: #f8f9fa; padding: 20px; border-radius: 8px;\">\n        <p style=\"font-size: 14px; color: #717182; margin: 0;\">\n          {{references}}\n        </p>\n      </div>\n    </div>\n    {{/if}}\n\n    {{#if budget}}\n    <div class=\"section\">\n      <h2 class=\"section-title\">💰 Orçamento</h2>\n      <div class=\"info-grid\">\n        <div class=\"info-item\">\n          <div class=\"info-label\">Orçamento Informado</div>\n          <div class=\"info-value\">{{budget}}</div>\n        </div>\n        <div class=\"info-item\">\n          <div class=\"info-label\">Prazo Desejado</div>\n          <div class=\"info-value\">{{deadline}}</div>\n        </div>\n      </div>\n    </div>\n    {{/if}}\n\n    <div class=\"section\">\n      <h2 class=\"section-title\">📊 Informações Adicionais</h2>\n      <div class=\"info-grid\">\n        <div class=\"info-item\">\n          <div class=\"info-label\">Origem</div>\n          <div class=\"info-value\">Formulário do Site</div>\n        </div>\n        <div class=\"info-item\">\n          <div class=\"info-label\">Data da Solicitação</div>\n          <div class=\"info-value\">{{requestDate}}</div>\n        </div>\n        <div class=\"info-item\">\n          <div class=\"info-label\">Status</div>\n          <div class=\"info-value\">Pendente</div>\n        </div>\n        <div class=\"info-item\">\n          <div class=\"info-label\">Prioridade</div>\n          <div class=\"info-value\">Alta</div>\n        </div>\n      </div>\n    </div>\n\n    <div style=\"text-align: center; margin: 30px 0;\">\n      <a href=\"mailto:{{email}}\" class=\"button\">Responder Cliente</a>\n      <a href=\"#\" class=\"button\">Ver no Admin Panel</a>\n    </div>\n\n    <div class=\"section\">\n      <p style=\"font-size: 14px; color: #717182; text-align: center;\">\n        Esta solicitação foi recebida através do formulário de contato.<br>\n        Entre em contato com o cliente o mais breve possível para discutir detalhes e orçamento.\n      </p>\n    </div>"
}