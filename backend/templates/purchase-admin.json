{
  "subject": "🎯 Novo Pedido de Compra - Ticket #{{orderId}}",
  "body": "<div class=\"section\">\n      <h1 style=\"font-family: 'Cinzel', serif; font-size: 28px; color: #030213; margin-bottom: 10px;\">\n        Novo Pedido Recebido!\n      </h1>\n      <p style=\"font-size: 16px; color: #717182;\">\n        Um cliente acabou de finalizar uma compra na loja digital. Detalhes abaixo para processamento.\n      </p>\n    </div>\n\n    <div class=\"highlight-box\">\n      <div class=\"highlight-title\">Ticket de Serviço</div>\n      <div class=\"highlight-value\">#{{orderId}}</div>\n      <div class=\"highlight-subtitle\">{{orderDate}}</div>\n    </div>\n\n    <div class=\"section\">\n      <h2 class=\"section-title\">👤 Dados do Cliente</h2>\n      <div class=\"info-grid\">\n        <div class=\"info-item\">\n          <div class=\"info-label\">Nome de Usuário</div>\n          <div class=\"info-value\">{{username}}</div>\n        </div>\n        <div class=\"info-item\">\n          <div class=\"info-label\">Email</div>\n          <div class=\"info-value\">{{email}}</div>\n        </div>\n        <div class=\"info-item\">\n          <div class=\"info-label\">ID do Usuário</div>\n          <div class=\"info-value\">{{userId}}</div>\n        </div>\n        <div class=\"info-item\">\n          <div class=\"info-label\">Serviços Anteriores</div>\n          <div class=\"info-value\">{{servicesCompleted}}</div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"section\">\n      <h2 class=\"section-title\">🛒 Detalhes da Compra</h2>\n      <table class=\"table\">\n        <thead>\n          <tr>\n            <th>Produto</th>\n            <th>Categoria</th>\n            <th>Preço Unitário</th>\n          </tr>\n        </thead>\n        <tbody>\n          {{#each items}}\n          <tr>\n            <td>{{name}}</td>\n            <td>{{category}}</td>\n            <td>R$ {{price}}</td>\n          </tr>\n          {{/each}}\n        </tbody>\n        <tfoot>\n          <tr class=\"total-row\">\n            <td colspan=\"2\"><strong>Valor Total</strong></td>\n            <td><strong>R$ {{totalAmount}}</strong></td>\n          </tr>\n        </tfoot>\n      </table>\n    </div>\n\n    <div class=\"section\">\n      <h2 class=\"section-title\">💰 Informações Financeiras</h2>\n      <div class=\"info-grid\">\n        <div class=\"info-item\">\n          <div class=\"info-label\">Valor Bruto</div>\n          <div class=\"info-value\">R$ {{totalAmount}}</div>\n        </div>\n        <div class=\"info-item\">\n          <div class=\"info-label\">Pontos Usados</div>\n          <div class=\"info-value\">{{pointsUsed}} pontos</div>\n        </div>\n        <div class=\"info-item\">\n          <div class=\"info-label\">Pontos Ganhos</div>\n          <div class=\"info-value\">{{pointsEarned}} pontos</div>\n        </div>\n        <div class=\"info-item\">\n          <div class=\"info-label\">Status do Pagamento</div>\n          <div class=\"info-value\">{{paymentStatus}}</div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"section\">\n      <h2 class=\"section-title\">🎮 Status de Gamificação</h2>\n      <div class=\"info-grid\">\n        <div class=\"info-item\">\n          <div class=\"info-label\">Pontos Totais do Cliente</div>\n          <div class=\"info-value\">{{totalPoints}} pontos</div>\n        </div>\n        <div class=\"info-item\">\n          <div class=\"info-label\">Nível Atual</div>\n          <div class=\"info-value\">{{level}}</div>\n        </div>\n        <div class=\"info-item\">\n          <div class=\"info-label\">Título Atual</div>\n          <div class=\"info-value\">{{title}}</div>\n        </div>\n        {{#if newReward}}\n        <div class=\"info-item\">\n          <div class=\"info-label\">Nova Recompensa</div>\n          <div class=\"info-value\">{{newReward.name}}</div>\n        </div>\n        {{/if}}\n      </div>\n    </div>\n\n    <div style=\"text-align: center; margin: 30px 0;\">\n      <a href=\"#\" class=\"button\">Ver no Admin Panel</a>\n      <a href=\"#\" class=\"button\">Contato do Cliente</a>\n    </div>\n\n    <div class=\"section\">\n      <p style=\"font-size: 14px; color: #717182; text-align: center;\">\n        Este pedido foi processado automaticamente pelo sistema.<br>\n        Verifique o painel administrativo para mais detalhes e acompanhamento.\n      </p>\n    </div>"
}